@namespace ECommerce.Components.Layout
@inherits LayoutComponentBase
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" @rendermode="InteractiveServer" />
<MudDialogProvider @rendermode="InteractiveServer" />
<MudSnackbarProvider @rendermode="InteractiveServer" />
<MudPopoverProvider @rendermode="InteractiveServer" />

<MudLayout>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Persistent"
               Elevation="0"
               Style="@sidebarStyle">

       
        <MudDrawerHeader Style="padding:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingBag"
                         Style="font-size:2rem; color:#6C63FF;" />
                <MudText Typo="Typo.h6" Style="font-weight:700; color:#6C63FF;">
                    ECommerce
                </MudText>
            </MudStack>
        </MudDrawerHeader>

        <MudDivider />

        <MudStack AlignItems="AlignItems.Center" Class="pa-4" Spacing="1">
            <MudAvatar Color="Color.Primary"
                       Style="width:56px; height:56px; font-size:1.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" />
            </MudAvatar>
            <MudText Typo="Typo.body1" Style="font-weight:600;">
                Admin Panel
            </MudText>
        </MudStack>

        <MudDivider Class="mb-2" />

        <MudNavMenu>

            <MudText Typo="Typo.caption"
                     Style="padding:8px 16px; color:#9CA3AF; font-weight:600;
                            letter-spacing:1px;">
                MAIN MENU
            </MudText>

            <MudNavLink Href="/admin/dashboard"
                        Icon="@Icons.Material.Filled.Dashboard"
                        Match="NavLinkMatch.All"
                        Style="@navLinkStyle">
                Dashboard
            </MudNavLink>

            <MudText Typo="Typo.caption"
                     Style="padding:8px 16px; margin-top:8px; color:#9CA3AF;
                            font-weight:600; letter-spacing:1px;">
                INVENTORY
            </MudText>

            <MudNavLink Href="/admin/products"
                        Icon="@Icons.Material.Filled.Inventory2"
                        Style="@navLinkStyle">
                Products
            </MudNavLink>

            <MudNavLink Href="/admin/categories"
                        Icon="@Icons.Material.Filled.Category"
                        Style="@navLinkStyle">
                Categories
            </MudNavLink>

            <MudText Typo="Typo.caption"
                     Style="padding:8px 16px; margin-top:8px; color:#9CA3AF;
                            font-weight:600; letter-spacing:1px;">
                SALES
            </MudText>

            <MudNavLink Href="/admin/orders"
                        Icon="@Icons.Material.Filled.ShoppingCart"
                        Style="@navLinkStyle">
                Orders
            </MudNavLink>

            <MudNavLink Href="/admin/users"
                        Icon="@Icons.Material.Filled.People"
                        Style="@navLinkStyle">
                Users
            </MudNavLink>

        </MudNavMenu>

        <MudSpacer />

        <MudDivider />

    </MudDrawer>

    <MudAppBar Elevation="0" Style="">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       OnClick="ToggleDrawer" />
        <MudSpacer />
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">

            <MudTooltip Text="Logout" Placement="Placement.Bottom" Color="Color.Primary">
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Style="color:#EF4444;"
                               OnClick="@OpenLogoutDialog" />
            </MudTooltip>

            <MudAvatar Color="Color.Primary"
                       Style="cursor:pointer; margin-left:8px;
                              width:36px; height:36px;">
                <MudIcon Icon="@Icons.Material.Filled.Person" />
            </MudAvatar>

        </MudStack>
    </MudAppBar>

    <MudMainContent Style="@mainContentStyle">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code { 
    private bool _drawerOpen = true;
    private int pendingOrders = 0;
    private string pageTitle = "Dashboard";

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6C63FF",
            Secondary = "#FF6584",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1A1A2E",
            Background = "#F8F9FA",
            Surface = "#FFFFFF",
            TextPrimary = "#1A1A2E",
            TextSecondary = "#6B7280",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#1A1A2E",
        }
    };

    private string sidebarStyle = "background:#FFFFFF; border-right:1px solid #E5E7EB; width:260px;";

    private string appBarStyle = "background:#FFFFFF; border-bottom:1px solid #E5E7EB; left:260px;";

    private string mainContentStyle = "background:#F8F9FA; min-height:100vh;";

    private string navLinkStyle = "color:#4B5563; border-radius:8px; margin:2px 8px;";

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;


    protected override void OnParametersSet()
    {
        var uri = Navigation.Uri;
        pageTitle = uri switch
        {
            var u when u.Contains("/admin/dashboard") => "Dashboard",
            var u when u.Contains("/admin/products") => "Products",
            var u when u.Contains("/admin/categories") => "Categories",
            var u when u.Contains("/admin/orders") => "Orders",
            var u when u.Contains("/admin/users") => "Users",
            var u when u.Contains("/admin/reports") => "Reports",
            _ => "Dashboard"
        };
    }
    private async Task OpenLogoutDialog()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to logout?");
        if (confirmed)
        {
            Navigation.NavigateTo("/account/logout", forceLoad: true);
        }
    }
}